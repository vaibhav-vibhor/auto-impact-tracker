# .gitignore for .NET projects
# Build results
bin/
obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
.vs/

# Rider
.idea/
*.sln.iml

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Output files
Outputs/

# NuGet packages
*.nupkg
# Package directories
packages/

# Others
*.vspscc
*.vssscc
_ReSharper*/

# Ignore coverage reports
coverage/
*.coverage
*.coveragexml

# Ignore temporary files
*.tmp
*.bak
*.swp
*.lock

